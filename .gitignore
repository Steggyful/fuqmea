# Local scratch (e.g. frame dumps from screen recordings)
.tmp-frames/

# OS / editor noise
desktop.ini
Thumbs.db
.DS_Store

# Supabase CLI (created after `supabase link` — local credentials)
.supabase/

# Supabase CLI link metadata (per-machine; do not commit)
supabase/.temp/

# Claude Code project-local config (machine-specific, no sensitive data but not repo content)
.claude/

# Editor local config
.vscode/settings.json
.cursor/
*.env
.env.local
.env.*.local

# Node (gallery scripts use plain `node`; no install required today)
node_modules/
.npm/

# Logs / local tooling noise
*.log
npm-debug.log*

# Python
__pycache__/
*.pyc
